<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.weblearning.bookstore.mapper.UserMapper">

    <insert id="add" parameterType="com.weblearning.bookstore.pojo.User">
        INSERT INTO bookstore.users (username, password) VALUES (#{username}, #{encodePassword})
    </insert>

    <update id="addBalance">
        UPDATE bookstore.users SET users.account_balance = account_balance + #{balance} WHERE user_id = #{userId}
    </update>

    <!-- 选择性更新用户信息：只更新传入的非空字段 -->
    <update id="update">
        UPDATE bookstore.users
        <set>
            <if test="user.username != null and user.username != ''">
                username = #{user.username},
            </if>
            <if test="user.name != null and user.name != ''">
                name = #{user.name},
            </if>
            <if test="user.address != null and user.address != ''">
                address = #{user.address},
            </if>
            <if test="user.accountBalance != null">
                account_balance = #{user.accountBalance},
            </if>
            <if test="user.creditLevel != null">
                credit_level = #{user.creditLevel},
            </if>
            <if test="user.discount != null">
                discount = #{user.discount},
            </if>
            <if test="user.overBalance != null">
                over_balance = #{user.overBalance},
            </if>
            <if test="user.role != null and user.role != ''">
                role = #{user.role},
            </if>
        </set>
        WHERE user_id = #{userId}
    </update>

    <update id="updatePwd">
        UPDATE bookstore.users SET password = #{encodePassword} WHERE user_id = #{userId}
    </update>

    <!-- 更新用户信用等级和折扣（旧方法，保留兼容性） -->
    <update id="updateCreditLevel">
        UPDATE bookstore.users SET credit_level = #{level}, discount = #{discount} WHERE user_id = #{userId}
    </update>

    <!-- 只更新用户信用等级（不更新折扣率）
    折扣率只与累计消费金额相关，由 DiscountService 管理
    -->
    <update id="updateCreditLevelOnly">
        UPDATE bookstore.users SET credit_level = #{level} WHERE user_id = #{userId}
    </update>

    <update id="updateOverBalance">
        UPDATE bookstore.users SET over_balance = #{overBalance} WHERE user_id = #{userId}
    </update>


    <select id="findByUserName" resultType="com.weblearning.bookstore.pojo.User">
        SELECT * FROM bookstore.users WHERE username = #{username}
    </select>

    <select id="findById" resultType="com.weblearning.bookstore.pojo.User">
        SELECT * FROM bookstore.users WHERE user_id = #{userId}
    </select>

    <select id="findOrderByUserId" resultType="com.weblearning.bookstore.pojo.Order">
        SELECT * FROM bookstore.orders WHERE user_id = #{userId}
    </select>

    <!-- 获取用户列表（带条件搜索） -->
    <select id="getUserList" resultType="com.weblearning.bookstore.pojo.User">
        SELECT * FROM bookstore.users
        <where>
            <if test="username != null and username != ''">
                username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="role != null and role != ''">
                AND role = #{role}
            </if>
        </where>
        ORDER BY user_id DESC
    </select>

    <!-- 获取所有用户 -->
    <select id="getAllUsers" resultType="com.weblearning.bookstore.pojo.User">
        SELECT * FROM bookstore.users ORDER BY user_id DESC
    </select>

    <!-- ==================== 阶段三：累计消费金额相关 ==================== -->

    <!-- 更新用户累计消费金额 -->
    <update id="updateTotalSpent">
        UPDATE bookstore.users
        SET total_spent = #{totalSpent}
        WHERE user_id = #{userId}
    </update>

    <!-- 更新用户折扣率 -->
    <update id="updateDiscount">
        UPDATE bookstore.users
        SET discount = #{discount}
        WHERE user_id = #{userId}
    </update>

    <!-- 更新折扣更新时间 -->
    <update id="updateDiscountUpdatedAt">
        UPDATE bookstore.users
        SET discount_updated_at = #{discountUpdatedAt}
        WHERE user_id = #{userId}
    </update>
</mapper>