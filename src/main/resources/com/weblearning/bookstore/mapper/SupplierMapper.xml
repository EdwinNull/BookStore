<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.weblearning.bookstore.mapper.SupplierMapper">

    <!-- 结果映射 -->
    <resultMap id="SupplierResultMap" type="com.weblearning.bookstore.pojo.Suppliers">
        <id property="supplierId" column="supplier_id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="name" column="name"/>
        <result property="address" column="address"/>
        <result property="contactInfo" column="contact_info"/>
        <result property="contactPerson" column="contact_person"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 添加供应商 -->
    <insert id="addSupplier" parameterType="com.weblearning.bookstore.pojo.Suppliers"
            useGeneratedKeys="true" keyProperty="supplierId">
        INSERT INTO suppliers (
            username,
            password,
            name,
            <if test="address != null and address != ''">address,</if>
            <if test="contactInfo != null and contactInfo != ''">contact_info,</if>
            <if test="contactPerson != null and contactPerson != ''">contact_person,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="email != null and email != ''">email,</if>
            status
        ) VALUES (
            #{username},
            #{password},
            #{name},
            <if test="address != null and address != ''">#{address},</if>
            <if test="contactInfo != null and contactInfo != ''">#{contactInfo},</if>
            <if test="contactPerson != null and contactPerson != ''">#{contactPerson},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="email != null and email != ''">#{email},</if>
            #{status}
        )
    </insert>

    <!-- 更新供应商信息 -->
    <update id="updateSupplier" parameterType="com.weblearning.bookstore.pojo.Suppliers">
        UPDATE suppliers
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="address != null and address != ''">address = #{address},</if>
            <if test="contactInfo != null and contactInfo != ''">contact_info = #{contactInfo},</if>
            <if test="contactPerson != null and contactPerson != ''">contact_person = #{contactPerson},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="email != null and email != ''">email = #{email},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            updated_at = CURRENT_TIMESTAMP
        </trim>
        WHERE supplier_id = #{supplierId}
    </update>

    <!-- 删除供应商 -->
    <delete id="deleteSupplier">
        DELETE FROM suppliers
        WHERE supplier_id = #{supplierId}
    </delete>

    <!-- 根据名称查询供应商 -->
    <select id="findByName" resultMap="SupplierResultMap">
        SELECT * FROM suppliers WHERE name = #{name}
    </select>

    <!-- 根据用户名查询供应商（用于登录） -->
    <select id="findByUsername" resultMap="SupplierResultMap">
        SELECT * FROM suppliers WHERE username = #{username}
    </select>

    <!-- 根据ID查询供应商 -->
    <select id="findById" resultMap="SupplierResultMap">
        SELECT * FROM suppliers WHERE supplier_id = #{supplierId}
    </select>

    <!-- 更新供应商状态 -->
    <update id="updateStatus">
        UPDATE suppliers
        SET status = #{status}, updated_at = CURRENT_TIMESTAMP
        WHERE supplier_id = #{supplierId}
    </update>

    <!-- 更新供应商密码 -->
    <update id="updatePassword">
        UPDATE suppliers
        SET password = #{password}, updated_at = CURRENT_TIMESTAMP
        WHERE supplier_id = #{supplierId}
    </update>

    <!-- 获取所有供应商列表 -->
    <select id="findAll" resultMap="SupplierResultMap">
        SELECT * FROM suppliers ORDER BY created_at DESC
    </select>

    <!-- 根据状态获取供应商列表 -->
    <select id="findByStatus" resultMap="SupplierResultMap">
        SELECT * FROM suppliers WHERE status = #{status} ORDER BY created_at DESC
    </select>

    <!-- 检查用户名是否存在 -->
    <select id="checkUsernameExists" resultType="int">
        SELECT COUNT(*) FROM suppliers WHERE username = #{username}
    </select>

</mapper>
